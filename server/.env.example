# ============================================
# CONFIGURACIÓN DEL SERVIDOR - SIDERMI UTN
# ============================================

# Puerto del servidor (default: 4000)
PORT=4000

# Entorno (development | production)
NODE_ENV=development

# ============================================
# BASE DE DATOS
# ============================================

# URI de conexión a MongoDB
MONGODB_URI=mongodb://localhost:27017/registro_utn

# ============================================
# SEGURIDAD (MUY IMPORTANTE EN PRODUCCIÓN)
# ============================================

# Clave secreta para firmar tokens JWT
# IMPORTANTE: Cambiar en producción. Generar con: openssl rand -hex 32
JWT_SECRET=cambiar_esto_en_produccion_generar_clave_segura_32_bytes

# Clave de cifrado para documentos (AES-256)
# IMPORTANTE: Cambiar en producción. Generar con: openssl rand -hex 32
# Una vez establecida, NO cambiarla o los archivos existentes no podrán descifrarse
DOCUMENT_ENCRYPTION_KEY=cambiar_esto_en_produccion_clave_aes_256_hex_64_chars

# Orígenes permitidos para CORS (separados por coma)
# En producción, especificar los dominios exactos
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000

# ============================================
# EMAIL (opcional, para notificaciones)
# ============================================

# Servidor SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASS=contraseña_smtp
SMTP_FROM=Sistema UTN <noreply@utn.ac.cr>

# ============================================
# NOTAS DE SEGURIDAD PARA PRODUCCIÓN
# ============================================

# 1. NUNCA usar las claves por defecto en producción
# 2. Usar HTTPS obligatorio (configurar en reverse proxy)
# 3. Configurar firewall para limitar acceso al puerto
# 4. Respaldar regularmente la base de datos
# 5. Respaldar la clave DOCUMENT_ENCRYPTION_KEY de forma segura
# 6. Revisar logs de auditoría periódicamente
# 7. Mantener actualizadas las dependencias de npm
