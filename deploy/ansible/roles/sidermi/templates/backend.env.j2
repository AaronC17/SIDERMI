# ============================================
# CONFIGURACIÓN DEL SERVIDOR - SIDERMI UTN
# Generado automaticamente por Ansible
# ============================================

# Puerto del servidor
PORT={{ backend_port }}

# Entorno
NODE_ENV=production

# BASE DE DATOS
MONGODB_URI={{ mongodb_uri }}

# SEGURIDAD
JWT_SECRET={{ jwt_secret_generated | default(jwt_secret) }}
DOCUMENT_ENCRYPTION_KEY={{ enc_key_generated | default(document_encryption_key) }}

# CORS
ALLOWED_ORIGINS=http://{{ ansible_host }},http://localhost,http://127.0.0.1

# EMAIL (opcional)
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port }}
SMTP_USER={{ smtp_user }}
SMTP_PASS={{ smtp_pass }}
SMTP_FROM={{ smtp_from }}
